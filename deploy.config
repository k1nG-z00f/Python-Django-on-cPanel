# =============================================================================
# deploy.config — Project-specific settings for deploy.sh
# =============================================================================
# Edit this file when using this template for a new project.
# It is sourced by deploy.sh at runtime.
# Do NOT store secrets here — use .env on the server for those.

# cPanel usernames (one per environment)
DEV_CPANEL_USER="devmyproject"
PROD_CPANEL_USER="myproject"

# Allowed hosts (comma-separated, no spaces)
DEV_HOSTS="dev.myproject.com,localhost,127.0.0.1"
PROD_HOSTS="myproject.com,www.myproject.com,localhost,127.0.0.1"

# Django settings module — must match the project package folder name
DJANGO_SETTINGS_MODULE="project.settings"
